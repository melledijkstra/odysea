{
  "name": "odysea",
  "version": "1.0.0",
  "private": true,
  "description": "A personal ecosystem",
  "author": "Melle Dijkstra",
  "license": "GPL-3.0-only",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "extension": "pnpm --filter=@odysea/extension run",
    "server": "pnpm --filter=@odysea/server run",
    "serverless": "pnpm --filter=@odysea/serverless run",
    "storybook": "turbo run storybook",
    "storybook:build": "turbo run storybook:build",
    "local:ci": "pnpm build && pnpm lint && CI=true pnpm test && pnpm test:e2e",
    "clean": "rm -rf .turbo node_modules && rm -fr apps/*/node_modules && pnpm cache delete"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.5.0",
    "eslint-plugin-svelte": "^3.18.0",
    "globals": "^17.7.0",
    "prettier": "^3.8.3",
    "svelte-eslint-parser": "^1.8.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9",
    "yalc": "^1.0.0-pre.53"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/melledijkstra/odysea.git"
  },
  "keywords": [
    "chrome",
    "extension",
    "homepage",
    "productivity"
  ],
  "bugs": {
    "url": "https://github.com/melledijkstra/odysea/issues"
  },
  "homepage": "https://github.com/melledijkstra/odysea#readme",
  "packageManager": "pnpm@10.26.2"
}
